---
import { experience, techColors } from '../utils/data';
---

<div class="flex flex-col">
  {[...experience].reverse().map((exp) => (
    <div class="exp-row flex items-start gap-4 py-4 px-3 rounded-xl transition-all duration-700 hover:bg-surface-hover group">
      <!-- Logo -->
      <div class="w-10 h-10 rounded-lg bg-white flex items-center justify-center shrink-0 overflow-hidden">
        <img
          src={exp.image}
          alt={exp.company}
          class="w-full h-full object-contain rounded-lg grayscale group-hover:grayscale-0 group-hover:transition-[filter] group-hover:duration-[0.32s]"
        />
      </div>

      <!-- Role + Company + Expandable Details -->
      <div class="flex-1 min-w-0">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-heading font-semibold text-base leading-tight">{exp.position}</p>
            <p class="text-body text-sm mt-0.5">{exp.company}</p>
          </div>
          <span class="text-muted text-sm font-mono shrink-0">{exp.duration}</span>
        </div>

        <!-- Expandable section -->
        <div class="exp-extra">
          <div class="overflow-hidden">
            <p class="text-body text-xs mt-2">{exp.description}</p>
            <div class="flex items-center gap-3 mt-2 flex-wrap">
              {exp.stack.map((tech) => (
                <span class="flex items-center gap-1.5 text-muted text-[10px] font-mono">
                  <span class="w-1.5 h-1.5 rounded-full" style={`background-color: ${techColors[tech] || 'rgba(255,255,255,0.3)'}`} />
                  {tech}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  ))}
</div>
