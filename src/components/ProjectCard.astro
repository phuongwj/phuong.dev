---
import { projects } from '../utils/data';

const visible = [...projects].reverse().slice(0, 3);
const remaining = projects.length - 3;
---

<div class="flex flex-col">
  {visible.map((project, i) => (
    <Fragment>
      {i > 0 && <hr class="border-t border-border-default my-1" />}
      <a href={project.github} target="_blank" class="project-card flex items-start gap-4 py-4 pl-4 pr-3 rounded-xl border-l-2 border-transparent transition-all duration-300 hover:border-white/40 hover:bg-white/4 hover:pl-5 group">
        <!-- Thumbnail -->
        <div class="w-36 h-24 rounded-lg bg-white/5 border border-border-default flex items-center justify-center shrink-0 overflow-hidden">
          <img src={project.image} alt={project.name} class="w-full h-full object-cover rounded-lg" />
        </div>

        <!-- Info -->
        <div class="flex-1 min-w-0 py-1">
          <p class="text-white/88 font-semibold text-base transition-colors duration-300 group-hover:text-white">{project.name}</p>
          <p class="text-body text-sm mt-1">{project.description}</p>
          <div class="flex items-center gap-2 mt-3 flex-wrap">
            {project.stack.map((tech) => (
              <span class="text-muted text-[11px] font-mono px-2 py-0.5 rounded border border-border-default bg-white/3">
                {tech.toLowerCase()}
              </span>
            ))}
          </div>
        </div>
      </a>
    </Fragment>
  ))}

  <div class="flex items-center gap-3 mt-4">
    <a href="/projects" class="text-body text-sm hover:text-heading transition-colors duration-300">view all projects</a>
    {remaining > 0 && (
      <span class="text-muted text-xs font-mono px-2 py-0.5 rounded border border-border-default">+{remaining}</span>
    )}
  </div>
</div>
